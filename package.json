{
  "name": "@eastagile/claude-harness",
  "version": "1.4.0",
  "description": "Harness engineering for Claude Code — scaffold CLAUDE.md, rules, hooks, skills, and architecture docs in one parallel run",
  "license": "MIT",
  "author": "East Agile <dev@eastagile.com> (https://eastagile.com)",
  "homepage": "https://github.com/quanhea/claude-harness#readme",
  "bugs": {
    "url": "https://github.com/quanhea/claude-harness/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/quanhea/claude-harness.git"
  },
  "keywords": [
    "claude-code",
    "claude-harness",
    "harness-engineering",
    "coding-agent",
    "codex",
    "scaffold",
